generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model StudyTask {
  id          String   @id @default(cuid())
  subject     String
  title       String
  description String?
  dayOfWeek   Int      @default(0)
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DailyGoal {
  id          String   @id @default(cuid())
  title       String
  completed   Boolean  @default(false)
  date        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GoalStreak {
  id          String   @id @default(cuid())
  currentDate String   @unique
  count       Int      @default(0)
  updatedAt   DateTime @updatedAt
}

model GymExercise {
  id          String   @id @default(cuid())
  name        String
  sets        Int      @default(3)
  reps        Int      @default(10)
  completed   Boolean  @default(false)
  dayOfWeek   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GymLog {
  id          String   @id @default(cuid())
  date        String
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CodeSnippet {
  id          String   @id @default(cuid())
  title       String
  language    String   @default("python")
  code        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChatMessage {
  id          String   @id @default(cuid())
  role        String
  content     String
  createdAt   DateTime @default(now())
}
